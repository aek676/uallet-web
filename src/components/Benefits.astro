---
---
<section id="benefits" class="py-32 px-8 bg-surface-container-lowest">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight max-w-xl">
        Diseñado para beneficiar a
        <span class="text-primary">toda la comunidad</span> universitaria.
      </h2>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="bg-surface-container-low p-10 rounded-2xl border border-outline-variant/10">
        <div class="flex items-center gap-4 mb-8">
          <span class="material-symbols-outlined text-primary text-4xl">school</span>
          <h3 class="font-headline text-2xl font-bold">Estudiantes</h3>
        </div>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary">check_circle</span>
            <div>
              <p class="font-bold">Recompensas reales</p>
              <p class="text-on-surface-variant text-sm">
                Convierte tu gasto diario en ahorro tangible para tus
                próximos consumos.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary">check_circle</span>
            <div>
              <p class="font-bold">Sin llevar cartera</p>
              <p class="text-on-surface-variant text-sm">
                Tu móvil es todo lo que necesitas para moverte por el
                campus de La Cañada.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary">check_circle</span>
            <div>
              <p class="font-bold">Identidad digital</p>
              <p class="text-on-surface-variant text-sm">
                Integrado con tu perfil universitario para accesos y
                beneficios exclusivos.
              </p>
            </div>
          </li>
        </ul>
      </div>
      <!-- Merchants -->
      <div class="bg-surface-container-low p-10 rounded-2xl border border-outline-variant/10">
        <div class="flex items-center gap-4 mb-8">
          <span class="material-symbols-outlined text-tertiary text-4xl">storefront</span>
          <h3 class="font-headline text-2xl font-bold">Comercios</h3>
        </div>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary">check_circle</span>
            <div>
              <p class="font-bold">Cero comisiones por micropagos</p>
              <p class="text-on-surface-variant text-sm">
                Mantén el 100% de tu margen en cafés, copias y menús
                económicos.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary">check_circle</span>
            <div>
              <p class="font-bold">Fidelización inteligente</p>
              <p class="text-on-surface-variant text-sm">
                Programas de puntos automáticos sin necesidad de tarjetas
                físicas.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary">check_circle</span>
            <div>
              <p class="font-bold">Liquidación automática</p>
              <p class="text-on-surface-variant text-sm">
                Gestión de caja digital e instantánea sin esperas
                bancarias.
              </p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
