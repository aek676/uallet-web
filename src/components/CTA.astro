<section id="cta" class="py-32 px-8">
  <div class="max-w-4xl mx-auto bg-primary-gradient p-1 rounded-3xl">
    <div class="bg-surface-container-lowest rounded-[calc(1.5rem-4px)] p-12 md:p-20 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 blur-[100px] -mr-32 -mt-32"></div>
      <h2 class="font-headline text-4xl md:text-5xl font-bold mb-6 tracking-tight">
        Sé de los primeros en probar UALlet en el campus de La Cañada.
      </h2>
      <p class="text-xl text-on-surface-variant mb-12">
        Estamos seleccionando estudiantes y comercios locales para la
        primera fase beta.
      </p>
      <form class="flex flex-col gap-4 max-w-md mx-auto">
        <input
          class="bg-surface-container-highest border-none rounded-xl px-6 py-4 text-on-surface focus:ring-2 focus:ring-primary/30 transition-all"
          placeholder="Tu correo institucional"
          type="email"
          required
        />
        <select
          class="bg-surface-container-highest border-none rounded-xl px-6 py-4 text-on-surface focus:ring-2 focus:ring-primary/30 transition-all appearance-none"
          required
        >
          <option value="estudiante">Soy Estudiante</option>
          <option value="comercio">Soy Comercio</option>
        </select>
        <button
          type="submit"
          class="bg-primary-gradient text-on-primary font-bold py-4 rounded-xl text-lg mt-4 active:scale-95 transition-transform"
        >
          Solicitar acceso anticipado
        </button>
      </form>
    </div>
  </div>
</section>
