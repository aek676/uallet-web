---
import { Image } from 'astro:assets';
import solanaGif from '../assets/solana.gif';
---
<section id="technology" class="py-32 px-8 overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">
    <div class="md:w-1/2">
      <h2 class="font-headline text-4xl font-bold mb-8">
        Tecnología
        <span class="italic text-on-surface-variant">invisible</span> y de
        vanguardia.
      </h2>
      <p class="text-lg text-on-surface-variant leading-relaxed mb-10">
        Construida sobre
        <span class="text-primary font-bold">Solana</span> mediante Smart
        Contracts. Transparencia absoluta, seguridad de grado
        militar y transacciones instantáneas con una interfaz accesible
        para todos.
      </p>
      <div class="grid grid-cols-2 gap-6">
        <div class="p-6 bg-surface-container-low rounded-xl border border-outline-variant/10">
          <p class="text-3xl font-headline font-bold text-secondary">
            0.0001€
          </p>
          <p class="text-xs uppercase tracking-widest font-label mt-2">
            Costo Transacción
          </p>
        </div>
        <div class="p-6 bg-surface-container-low rounded-xl border border-outline-variant/10">
          <p class="text-3xl font-headline font-bold text-secondary">
            &lt;400ms
          </p>
          <p class="text-xs uppercase tracking-widest font-label mt-2">
            Tiempo Confirmación
          </p>
        </div>
      </div>
    </div>
    <div class="md:w-1/2 relative">
      <Image
        src={solanaGif}
        alt="Solana"
        class="rounded-xl"
        loading="lazy"
      />
    </div>
  </div>
</section>
