---
---
<section id="technology" class="py-32 px-8 overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">
    <div class="md:w-1/2">
      <h2 class="font-headline text-4xl font-bold mb-8">
        Tecnología
        <span class="italic text-on-surface-variant">invisible</span> y de
        vanguardia.
      </h2>
      <p class="text-lg text-on-surface-variant leading-relaxed mb-10">
        Construida sobre
        <span class="text-primary font-bold">Solana</span> mediante Smart
        Contracts en Rust. Transparencia absoluta, seguridad de grado
        militar y transacciones instantáneas con una interfaz accesible
        para todos.
      </p>
      <div class="grid grid-cols-2 gap-6">
        <div class="p-6 bg-surface-container-low rounded-xl border border-outline-variant/10">
          <p class="text-3xl font-headline font-bold text-secondary">
            0.0001€
          </p>
          <p class="text-xs uppercase tracking-widest font-label mt-2">
            Costo Transacción
          </p>
        </div>
        <div class="p-6 bg-surface-container-low rounded-xl border border-outline-variant/10">
          <p class="text-3xl font-headline font-bold text-secondary">
            &lt;400ms
          </p>
          <p class="text-xs uppercase tracking-widest font-label mt-2">
            Tiempo Confirmación
          </p>
        </div>
      </div>
    </div>
    <div class="md:w-1/2 relative">
      <div class="absolute -inset-10 bg-secondary/5 blur-[80px] rounded-full"></div>
      <div class="relative bg-surface-container-highest aspect-square rounded-3xl p-1 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-secondary/20"></div>
        <div class="w-full h-full bg-surface-container-highest rounded-[calc(1.5rem-4px)] flex items-center justify-center">
          <span
            class="material-symbols-outlined text-[120px] text-primary/40"
            style='font-variation-settings: "FILL" 1'
            >terminal</span
          >
        </div>
      </div>
    </div>
  </div>
</section>